{
  "name": "galaxy_gen_client",
  "version": "0.0.1",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "start": "webpack serve --open",
    "dev": "webpack serve --open",
    "dev:wasm": "cargo watch -w src/rust -w Cargo.toml -s 'wasm-pack build --dev'",
    "dev:all": "npm run dev:wasm & npm run dev",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "pretest:e2e": "wasm-pack build && npm install ./pkg --no-save",
    "lint": "eslint 'src/**/*.{ts,tsx,js,jsx}' 'e2e/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'src/**/*.{ts,tsx,js,jsx}' 'e2e/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,css}' 'e2e/**/*.{ts,tsx}' '*.{js,json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx,css}' 'e2e/**/*.{ts,tsx}' '*.{js,json,md}'",
    "typecheck": "tsc --noEmit"
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react",
      "@babel/preset-typescript"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.3",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@webgpu/types": "^0.1.69",
    "autoprefixer": "^10.5.0",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "crypto-browserify": "^3.12.1",
    "css-loader": "^7.1.4",
    "d3": "^7.9.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "galaxy_gen_backend": "file:pkg",
    "postcss": "^8.5.10",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.3",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
